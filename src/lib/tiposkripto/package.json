{
  "name": "testeranto.tiposkripto",
  "version": "0.4.0",
  "description": "the typescript implementation of testeranto",
  "author": "adamwong246@gmail.com",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build-module": "tsc -p tsconfig.module.json",
    "build-common": "tsc -p tsconfig.common.json",
    "build-types": "tsc -p tsconfig.types.json",
    "build": "sh prebuild.sh; cp ./cjs-shim.js ./cjs-shim.js; tsc -p tsconfig.types.json; sh postBuild.sh; node bundle.js",
    "prepack": "yarn run build"
  },
  "files": [
    "dist/**",
    "package.json",
    "README*",
    "LICENSE*"
  ],
  "exports": {
    "./CoreTypes": {
      "types": "./dist/types/lib/tiposkripto/src/CoreTypes.d.ts"
    },
    "./node": {
      "import": "./dist/module/Node.js",
      "types": "./dist/types/lib/tiposkripto/src/Node.d.ts"
    },
    "./web": {
      "import": "./dist/module/Web.js",
      "types": "./dist/types/lib/tiposkripto/src/Web.d.ts"
    }
  },
  "dependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
