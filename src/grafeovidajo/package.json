{
  "name": "grafeovidajo",
  "version": "0.0.10",
  "description": "Visualization library for Testeranto",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./charts/EisenhowerMatrix": {
      "import": "./dist/charts/EisenhowerMatrix.js",
      "require": "./dist/charts/EisenhowerMatrix.js",
      "types": "./dist/charts/EisenhowerMatrix.d.ts"
    },
    "./charts/GanttChart": {
      "import": "./dist/charts/GanttChart.js",
      "require": "./dist/charts/GanttChart.js",
      "types": "./dist/charts/GanttChart.d.ts"
    },
    "./charts/KanbanBoard": {
      "import": "./dist/charts/KanbanBoard.js",
      "require": "./dist/charts/KanbanBoard.js",
      "types": "./dist/charts/KanbanBoard.d.ts"
    },
    "./charts/TreeGraph": {
      "import": "./dist/charts/TreeGraph.js",
      "require": "./dist/charts/TreeGraph.js",
      "types": "./dist/charts/TreeGraph.d.ts"
    },
    "./core/types": {
      "import": "./dist/core/types.js",
      "require": "./dist/core/types.js",
      "types": "./dist/core/types.d.ts"
    }
  },
  "scripts": {
    "build": "node bundle.js",
    "dev": "tsc --watch",
    "build:tsc": "tsc",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/react": "^18.2.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@types/glob": "^9.0.0",
    "glob": "^13.0.6"
  }
}