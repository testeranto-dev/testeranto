{
  "name": "testeranto",
  "displayName": "Testeranto",
  "description": "the AI powered test framework for polyglot projects",
  "version": "0.351.0",
  "engines": {
    "node": ">=20.19.0",
    "vscode": "^1.60.0",
    "bun": ">=1.0.0"
  },
  "publisher": "adamwong246",
  "main": "./dist/vscode/extension.mjs",
  "type": "module",
  "types": "./dist/index.d.mts",
  "module": "dist/module/index.js",
  "bin": {
    "testeranto": "./dist/testeranto"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:testeranto.showTests",
    "onCommand:testeranto.runTest",
    "onCommand:testeranto.openConfig",
    "onCommand:testeranto.openFile",
    "onCommand:testeranto.refresh",
    "onCommand:testeranto.retryConnection",
    "onCommand:testeranto.startServer",
    "onCommand:testeranto.refreshDockerProcesses",
    "onCommand:testeranto.refreshAiderProcesses",
    "onCommand:testeranto.refreshFileTree",
    "onCommand:testeranto.showProcessLogs",
    "onCommand:testeranto.openAiderTerminal",
    "onCommand:testeranto.launchAgent",
    "onView:testeranto.runtimeView",
    "onView:testeranto.dockerProcessView",
    "onView:testeranto.aiderProcessView",
    "onView:testeranto.fileTreeView",
    "onView:testeranto.agentView",
    "onView:testeranto.viewView",
    "workspaceContains:**/testeranto/extension-config.json",
    "workspaceContains:**/testeranto/reports/**/*.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "testeranto",
          "title": "Testeranto",
          "icon": "$(beaker)"
        }
      ]
    },
    "menus": {
      "view/title": []
    },
    "views": {
      "testeranto": [
        {
          "id": "testeranto.runtimeView",
          "name": "Runtime Tests",
          "icon": "$(beaker)"
        },
        {
          "id": "testeranto.dockerProcessView",
          "name": "Docker Processes",
          "icon": "$(server)"
        },
        {
          "id": "testeranto.aiderProcessView",
          "name": "Aider Processes",
          "icon": "$(comment-discussion)"
        },
        {
          "id": "testeranto.fileTreeView",
          "name": "File Perspective",
          "icon": "$(files)"
        },
        {
          "id": "testeranto.agentView",
          "name": "Agents",
          "icon": "$(person)"
        },
        {
          "id": "testeranto.viewView",
          "name": "Views",
          "icon": "$(eye)"
        }
      ]
    },
    "commands": [
      {
        "command": "testeranto.showTests",
        "title": "Testeranto: Show Tests"
      },
      {
        "command": "testeranto.runTest",
        "title": "Testeranto: Run Test"
      },
      {
        "command": "testeranto.openConfig",
        "title": "Testeranto: Open Configuration"
      },
      {
        "command": "testeranto.openFile",
        "title": "Testeranto: Open File"
      },
      {
        "command": "testeranto.refresh",
        "title": "Testeranto: Refresh All Views"
      },
      {
        "command": "testeranto.retryConnection",
        "title": "Testeranto: Retry Connection"
      },
      {
        "command": "testeranto.startServer",
        "title": "Testeranto: Start Server"
      },
      {
        "command": "testeranto.refreshDockerProcesses",
        "title": "Testeranto: Refresh Docker Processes"
      },
      {
        "command": "testeranto.refreshAiderProcesses",
        "title": "Testeranto: Refresh Aider Processes"
      },
      {
        "command": "testeranto.refreshFileTree",
        "title": "Testeranto: Refresh File Tree"
      },
      {
        "command": "testeranto.refreshViewTree",
        "title": "Testeranto: Refresh Views"
      },
      {
        "command": "testeranto.showProcessLogs",
        "title": "Testeranto: Show Process Logs"
      },
      {
        "command": "testeranto.openAiderTerminal",
        "title": "Testeranto: Open Aider Terminal"
      },
      {
        "command": "testeranto.launchAgent",
        "title": "Testeranto: Launch Agent"
      },
      {
        "command": "testeranto.refreshAgents",
        "title": "Testeranto: Refresh Agents"
      },
      {
        "command": "testeranto.openProcessTerminal",
        "title": "Testeranto: Open Process Terminal"
      },
      {
        "command": "testeranto.openView",
        "title": "Testeranto: Open View"
      },
      {
        "command": "testeranto.refreshViewTree",
        "title": "Testeranto: Refresh Views"
      },
      {
        "command": "testeranto.openView",
        "title": "Testeranto: Open View"
      }
    ]
  },
  "repository": "git@github.com:adamwong246/testeranto.git",
  "homepage": "https://github.com/testeranto-dev/testeranto",
  "author": "adam wong <adamwong246@gmail.com>",
  "license": "MIT",
  "categories": [
    "Testing",
    "Other"
  ],
  "scripts": {
    "storybook": "rakonto --dev",
    "build-storybook": "rakonto",
    "dev4": "yarn dev2 && testeranto init && testeranto dev",
    "dev3": "yarn package:vsce && yarn dev2 && testeranto init && testeranto dev",
    "serve": "testeranto dev",
    "dev2": "yarn bundle && bun build ./src/index.ts --compile --outfile ./dist/testeranto && bun link",
    "dev": "yarn build:server && yarn link:server",
    "summarizeLicenses": "yarn licenses list > ALL_LICENSES.txt; yarn license-checker >> ALL_LICENSES.txt; yarn license-checker --summary >> ALL_LICENSES.txt",
    "compile-docs": "node scripts/compile-docs.js",
    "prepublish": "self-import",
    "vscode:prepublish": "yarn run bundle",
    "compile": "yarn run bundle",
    "watch": "yarn run bundle --watch",
    "package:vsce": "npx vsce package",
    "package:full": "node scripts/package-extension.js",
    "build:server": "bun build ./src/index.ts --compile --outfile ./dist/testeranto",
    "compile:server": "bun compile ./src/index.ts --outfile testeranto-app --banner=\"#!/usr/bin/env bun\"",
    "prepublishOnly:server": "bun run build",
    "make:server": "bun run build:server && bun link",
    "bundle": "node bundle.js",
    "publish:ruby": "cd src/lib/rubeno/ && gem build rubeno.gemspec",
    "launch:extension": "code --extensionDevelopmentPath=\"$PWD\""
  },
  "keywords": [
    "testeranto",
    "testing",
    "bdd",
    "ATDD"
  ],
  "exports": {
    "./src/vscode/defaultViews/index.ts": {
      "import": "./src/vscode/defaultViews/index.ts",
      "require": "./src/vscode/defaultViews/index.ts",
      "types": "./src/vscode/defaultViews/index.ts"
    },
    "./src/*": {
      "import": "./src/*"
    },
    "./stakeholderApp/*": {
      "import": "./src/stakeholderApp/*"
    },
    "./src/cjs-shim.ts": {
      "import": "./dist/cjs-shim.js",
      "require": "./dist/cjs-shim.js"
    },
    "./Puppeteer": {
      "import": "./dist/prebuild/Puppeteer.mjs",
      "require": "./dist/prebuild/Puppeteer.mjs"
    },
    "./src/lib": {
      "import": "./src/lib/index.ts",
      "require": "./src/lib/index.ts"
    },
    "./src/lib/abstractBase": {
      "import": "./src/lib/abstractBase.ts",
      "require": "./src/lib/abstractBase.ts"
    },
    "./src/lib/Sidecar": {
      "import": "./src/lib/Sidecar.ts",
      "require": "./src/lib/Sidecar.ts"
    },
    "./src/PureSidecar": {
      "import": "./src/PureSidecar.ts",
      "require": "./src/PureSidecar.ts"
    },
    "./src/NodeSidecar": {
      "import": "./src/NodeSidecar.ts",
      "require": "./src/NodeSidecar.ts"
    },
    "./src/WebSidecar": {
      "import": "./src/WebSidecar.ts",
      "require": "./src/WebSidecar.ts"
    },
    "./src/CoreTypes": {
      "import": "./src/CoreTypes.ts",
      "require": "./src/CoreTypes.ts",
      "types": "./src/CoreTypes.d.ts"
    },
    "./src/Types": {
      "import": "./src/Types.ts",
      "require": "./src/Types.ts"
    },
    "./src/utils": {
      "import": "./utils.ts",
      "require": "./utils.ts"
    },
    "./src/Features": {
      "import": "./dist/module/Features.js",
      "require": "./dist/common/Features.js"
    },
    "./src/prompt": {
      "import": "./dist/module/src/prompt.js",
      "require": "./dist/module/src/prompt.js"
    },
    "./src/Project": {
      "import": "./dist/module/src/Project.js",
      "require": "./dist/common/src/Project.js"
    },
    "./src/Web": {
      "import": "./src/Web.ts",
      "require": "./src/Web.ts"
    },
    "./src/Node": {
      "import": "./src/Node.ts",
      "require": "./src/Node.ts"
    },
    "./src/Pure": {
      "import": "./src/Pure.ts",
      "require": "./src/Pure.ts"
    },
    "./src/PM": {
      "import": "./src/PM.ts",
      "require": "./src/PM.ts"
    },
    "./src/Init": {
      "import": "./dist/module/src/Init.js",
      "require": "./dist/common/src/Init.js"
    },
    "./src/preload": {
      "import": "./dist/module/preload.js",
      "require": "./dist/common/preload.js"
    },
    "./dist/module/lib/core": {
      "import": "./dist/module/lib/core.js",
      "require": "./dist/common/lib/core.js"
    },
    "./dist/module/lib/abstractBase": {
      "import": "./dist/module/lib/abstractBase.js",
      "require": "./dist/common/lib/abstractBase.js"
    },
    "./dist/module/lib/baseBuilder": {
      "import": "./dist/module/lib/baseBuilder.js",
      "require": "./dist/common/lib/baseBuilder.js"
    },
    "./dist/module/lib/classBuilder": {
      "import": "./dist/module/lib/classBuilder.js",
      "require": "./dist/common/lib/classBuilder.js"
    },
    "./dist/module/NodeWriter": {
      "import": "./dist/module/NodeWriter.js",
      "require": "./dist/common/NodeWriter.js"
    },
    "./src/views": {
      "import": "./src/views/index.ts",
      "require": "./src/views/index.ts"
    },
    "./src/*/*": "./src/*/*.ts",
    "./src/*/*/*": "./src/*/*/*.ts",
    "./src/*/*/*/*": "./src/*/*/*/*.ts"
  },
  "peerDependencies": {
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/react-test-renderer": "19.0.0",
    "eslint": "9.23.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "ts-node": "^10.9.1",
    "typescript": "4.8.2",
    "typescript-eslint": "^8.29.0"
  },
  "devDependencies": {
